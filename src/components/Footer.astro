<style>
	footer {
		padding: 2em 1em 4em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
	}
	.copy {
		margin: 0 0 0.5em;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1.2em;
		margin-top: 0.6em;
	}
	.social-links a {
		display: flex;
		color: rgb(var(--gray));
		transition: color 0.15s ease;
	}
	.social-links a:hover {
		color: var(--accent);
	}
</style>
