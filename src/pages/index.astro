---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				padding: 2rem 0 1rem;
			}
			.eyebrow {
				display: flex;
				align-items: center;
				flex-wrap: wrap;
				gap: 0.55rem;
				margin-bottom: 0.9rem;
			}
			.who {
				color: rgb(var(--gray-dark));
				font-weight: 700;
				font-size: 1rem;
			}
			.badge {
				display: inline-flex;
				align-items: center;
				gap: 0.4em;
				padding: 0.28em 0.75em;
				border-radius: 999px;
				background: color-mix(in srgb, var(--accent) 10%, white);
				border: 1px solid color-mix(in srgb, var(--accent) 22%, white);
				color: var(--accent);
				font-size: 0.82rem;
				font-weight: 700;
			}
			.hero h1 {
				font-size: clamp(1.9rem, 5.5vw, 2.8rem);
				line-height: 1.15;
				margin-bottom: 0.8rem;
				text-wrap: balance;
			}
			.lead {
				font-size: clamp(1.05rem, 3vw, 1.18rem);
				color: rgb(var(--gray-dark));
				max-width: 46ch;
				margin-bottom: 1.8rem;
				text-wrap: pretty;
			}
			.cta {
				display: flex;
				flex-wrap: wrap;
				gap: 0.7rem;
			}
			.btn {
				display: inline-block;
				padding: 0.65em 1.3em;
				border-radius: 999px;
				border: 1px solid rgb(var(--gray-light));
				background: #fff;
				color: rgb(var(--gray-dark));
				font-weight: 700;
				text-decoration: none;
				transition: 0.15s ease;
			}
			.btn:hover {
				transform: translateY(-2px);
				box-shadow: var(--box-shadow);
				border-color: var(--accent);
				color: var(--accent);
			}
			.btn.primary {
				background: var(--accent);
				border-color: var(--accent);
				color: #fff;
			}
			.btn.primary:hover {
				color: #fff;
				opacity: 0.92;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="eyebrow">
					<span class="who">박지원</span>
					<span class="badge">AI Engineer @ Mono</span>
				</p>
				<h1>AI 에이전트를 만들며 부딪힌 것들을 기록합니다</h1>
				<p class="lead">
					tool calling 루프, 컨텍스트 설계, 멀티에이전트 디버깅처럼 — 추상적 개론 말고
					<strong>실제로 겪은 문제와 해결 과정</strong>을 씁니다.
				</p>
				<div class="cta">
					<a class="btn primary" href="/blog/">글 보러 가기 →</a>
					<a class="btn" href="/about/">About</a>
				</div>
				<SocialLinks align="start" />
			</section>
		</main>
		<Footer />
	</body>
</html>
