---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				padding: 2rem 0 1rem;
			}
			.eyebrow {
				color: var(--accent);
				font-weight: 700;
				font-size: 0.95rem;
				letter-spacing: 0.02em;
				margin-bottom: 0.6rem;
			}
			.hero h1 {
				font-size: 2.8rem;
				line-height: 1.15;
				margin-bottom: 0.8rem;
			}
			.lead {
				font-size: 1.15rem;
				color: rgb(var(--gray-dark));
				max-width: 38ch;
				margin-bottom: 1.8rem;
			}
			.cta {
				display: flex;
				flex-wrap: wrap;
				gap: 0.7rem;
			}
			.btn {
				display: inline-block;
				padding: 0.65em 1.3em;
				border-radius: 999px;
				border: 1px solid rgb(var(--gray-light));
				background: #fff;
				color: rgb(var(--gray-dark));
				font-weight: 700;
				text-decoration: none;
				transition: 0.15s ease;
			}
			.btn:hover {
				transform: translateY(-2px);
				box-shadow: var(--box-shadow);
				border-color: var(--accent);
				color: var(--accent);
			}
			.btn.primary {
				background: var(--accent);
				border-color: var(--accent);
				color: #fff;
			}
			.btn.primary:hover {
				color: #fff;
				opacity: 0.92;
			}
			@media (max-width: 600px) {
				.hero h1 {
					font-size: 2.1rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="eyebrow">박지원 · AI Engineer @ Mono</p>
				<h1>AI 에이전트를 만들며<br />부딪힌 것들을 기록합니다</h1>
				<p class="lead">
					tool calling 루프, 컨텍스트 설계, 멀티에이전트 디버깅처럼 — 추상적 개론 말고
					<strong>실제로 겪은 문제와 해결 과정</strong>을 씁니다.
				</p>
				<div class="cta">
					<a class="btn primary" href="/blog/">글 보러 가기 →</a>
					<a class="btn" href="/about/">About</a>
				</div>
				<SocialLinks align="start" />
			</section>
		</main>
		<Footer />
	</body>
</html>
