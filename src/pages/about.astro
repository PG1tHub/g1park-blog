---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import SocialLinks from '../components/SocialLinks.astro';
import profile from '../assets/profile.jpg';

const title = 'About · 박지원 (Jiwon Park)';
const description =
	'Mono에서 프로덕션 AI 에이전트(멀티에이전트·RAG·Text-to-SQL)를 만드는 AI 엔지니어 박지원입니다.';

// 경력 기간 자동 계산 (시작: 2026년 3월) — 빌드 시점 fallback. 브라우저에서 실시간 재계산됨.
const EXP_START = '2026-03';
function monthsSince(s: string) {
	const [y, m] = s.split('-').map(Number);
	const now = new Date();
	return (now.getFullYear() - y) * 12 + (now.getMonth() + 1 - m) + 1;
}
const expMonths = monthsSince(EXP_START);
const yy = Math.floor(expMonths / 12);
const mm = expMonths % 12;
const tenureKo = [yy ? `${yy}년` : '', mm ? `${mm}개월` : ''].filter(Boolean).join(' ') || '0개월';
const tenureEn =
	[yy ? `${yy} yr${yy > 1 ? 's' : ''}` : '', mm ? `${mm} mo${mm > 1 ? 's' : ''}` : '']
		.filter(Boolean)
		.join(' ') || '0 mos';
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.about {
				max-width: 720px;
				margin: 0 auto;
			}
			.profile {
				text-align: center;
				margin-bottom: 1.5rem;
			}
			.avatar {
				width: 168px;
				height: 168px;
				border-radius: 50%;
				object-fit: cover;
				box-shadow: var(--box-shadow);
			}
			.lang-toggle {
				display: flex;
				justify-content: center;
				gap: 0.35rem;
				margin-bottom: 2rem;
			}
			.lang-toggle button {
				font: inherit;
				cursor: pointer;
				padding: 0.3em 0.9em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 999px;
				background: #fff;
				color: rgb(var(--gray));
				transition: 0.15s ease;
			}
			.lang-toggle button:hover {
				border-color: var(--accent);
				color: var(--accent);
			}
			.lang-toggle button.active {
				background: var(--accent);
				border-color: var(--accent);
				color: #fff;
			}
			.name {
				margin-bottom: 0.2em;
			}
			.name span {
				color: rgb(var(--gray));
				font-size: 0.5em;
				font-weight: 400;
				white-space: nowrap;
			}
			.exp {
				border-left: 3px solid color-mix(in srgb, var(--accent) 35%, white);
				padding-left: 1em;
				margin: 0.5em 0 1.5em;
			}
			.exp-role {
				margin: 0 0 0.1em;
				font-weight: 700;
				color: rgb(var(--black));
			}
			.exp-org {
				margin: 0 0 0.3em;
			}
			.exp-meta {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.95rem;
				line-height: 1.5;
			}
			.stack {
				list-style: none;
				padding: 0;
			}
			.stack li {
				margin-bottom: 0.6em;
			}
			.stack .cat {
				display: inline-block;
				min-width: 9.5em;
				font-weight: 700;
				color: rgb(var(--black));
			}
			@media (max-width: 600px) {
				.stack .cat {
					display: block;
					min-width: 0;
					margin-bottom: 0.1em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<article class="about">
				<div class="profile">
					<Image
						class="avatar"
						src={profile}
						alt="박지원 (Jiwon Park)"
						width={336}
						height={336}
					/>
				</div>

				<div class="lang-toggle" role="group" aria-label="언어 선택 / Language">
					<button type="button" data-set="ko" class="active">한국어</button>
					<button type="button" data-set="en">EN</button>
				</div>

				<!-- 한국어 -->
				<div data-lang="ko">
					<h1 class="name">박지원 <span>· AI Engineer</span></h1>
					<p>
						프로덕션에서 실제 트래픽을 받는 <strong>AI 에이전트</strong>를 아키텍처 설계부터
						배포까지 직접 만듭니다.
					</p>
					<p>
						지금은 <strong>Mono</strong>에서 고객지원 AI 에이전트를 만들고 있어요. 멀티에이전트
						오케스트레이션, RAG, Text-to-SQL까지 — 하나의 시스템을 처음부터 끝까지 책임지고 짜는
						일을 좋아합니다.
					</p>
					<p>
						이 블로그는 그 과정에서 부딪힌 <strong>실전 문제와 해결 과정</strong>을 기록하는
						공간입니다.
					</p>

					<h2>경력</h2>
					<div class="exp">
						<p class="exp-role">AI Research Engineer · Customer Support AI Agent</p>
						<p class="exp-org">Mono Communications (모노커뮤니케이션즈) · 정규직</p>
						<p class="exp-meta">
							2026.03 – 현재 · <span class="tenure" data-start="2026-03" data-fmt="ko"
								>{tenureKo}</span
							>
						</p>
						<p class="exp-meta">서울, 대한민국 · 대면근무</p>
					</div>

					<h2>기술 스택</h2>
					<ul class="stack">
						<li><span class="cat">AI / Agents</span> LangGraph · LangChain · RAG · Text-to-SQL · Multi-Agent · Self-Correction</li>
						<li><span class="cat">LLM</span> Anthropic Claude API · OpenAI API</li>
						<li><span class="cat">Data / Infra</span> pgvector · ChromaDB · BGE-M3 · PostgreSQL · Neo4j · FastAPI · Docker · Linux</li>
						<li><span class="cat">Backend / Frontend</span> Spring Boot · React · Python · Java 21</li>
					</ul>

					<h2>링크</h2>
					<SocialLinks />
				</div>

				<!-- English -->
				<div data-lang="en" hidden>
					<h1 class="name">Jiwon Park <span>· AI Engineer</span></h1>
					<p>
						I build production <strong>AI agents</strong> end-to-end — from architecture to
						deployment.
					</p>
					<p>
						I'm currently building a customer-support AI agent at <strong>Mono</strong>:
						multi-agent orchestration, RAG, and Text-to-SQL. I enjoy owning a system from design
						all the way to production.
					</p>
					<p>
						This blog is where I write up the <strong>real problems I run into — and how I solve
						them.</strong>
					</p>

					<h2>Experience</h2>
					<div class="exp">
						<p class="exp-role">AI Research Engineer · Customer Support AI Agent</p>
						<p class="exp-org">Mono Communications · Full-time</p>
						<p class="exp-meta">
							Mar 2026 – Present · <span class="tenure" data-start="2026-03" data-fmt="en"
								>{tenureEn}</span
							>
						</p>
						<p class="exp-meta">Seoul, South Korea · On-site</p>
					</div>

					<h2>Tech Stack</h2>
					<ul class="stack">
						<li><span class="cat">AI / Agents</span> LangGraph · LangChain · RAG · Text-to-SQL · Multi-Agent · Self-Correction</li>
						<li><span class="cat">LLM</span> Anthropic Claude API · OpenAI API</li>
						<li><span class="cat">Data / Infra</span> pgvector · ChromaDB · BGE-M3 · PostgreSQL · Neo4j · FastAPI · Docker · Linux</li>
						<li><span class="cat">Backend / Frontend</span> Spring Boot · React · Python · Java 21</li>
					</ul>

					<h2>Links</h2>
					<SocialLinks />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<script>
	const buttons = Array.from(
		document.querySelectorAll('.lang-toggle button'),
	) as HTMLButtonElement[];
	const blocks = Array.from(document.querySelectorAll('[data-lang]')) as HTMLElement[];

	function apply(lang: string) {
		blocks.forEach((b) => (b.hidden = b.dataset.lang !== lang));
		buttons.forEach((btn) => btn.classList.toggle('active', btn.dataset.set === lang));
		try {
			localStorage.setItem('about-lang', lang);
		} catch {}
	}

	buttons.forEach((btn) => btn.addEventListener('click', () => apply(btn.dataset.set || 'ko')));

	let saved = 'ko';
	try {
		saved = localStorage.getItem('about-lang') || 'ko';
	} catch {}
	apply(saved);

	// 경력 기간 실시간 계산 — 방문 시점 기준 (빌드 안 해도 항상 최신)
	function monthsSince(s: string) {
		const [y, m] = s.split('-').map(Number);
		const now = new Date();
		return (now.getFullYear() - y) * 12 + (now.getMonth() + 1 - m) + 1;
	}
	document.querySelectorAll('.tenure').forEach((node) => {
		const el = node as HTMLElement;
		const total = monthsSince(el.dataset.start || '2026-03');
		const y = Math.floor(total / 12);
		const mo = total % 12;
		if (el.dataset.fmt === 'en') {
			el.textContent =
				[y ? `${y} yr${y > 1 ? 's' : ''}` : '', mo ? `${mo} mo${mo > 1 ? 's' : ''}` : '']
					.filter(Boolean)
					.join(' ') || '0 mos';
		} else {
			el.textContent =
				[y ? `${y}년` : '', mo ? `${mo}개월` : ''].filter(Boolean).join(' ') || '0개월';
		}
	});
</script>
